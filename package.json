{
  "name": "gold-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "label-server": "node label-server.js",
    "label-server:pack-win": "powershell -ExecutionPolicy Bypass -File packaging/label-bridge-win/scripts/build-release.ps1",
    "dev:web": "npm --workspace @gold/web run dev",
    "dev:api": "npm --workspace @gold/api run dev",
    "build": "npm --workspace @gold/shared run build && npm --workspace @gold/api run build && npm --workspace @gold/web run build",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "import:legacy": "node scripts/import-localstorage.mjs",
    "migrate:turso:export": "node scripts/turso-export.mjs",
    "migrate:turso:import": "node scripts/supabase-import.mjs",
    "migrate:turso:reconcile": "node scripts/reconcile-turso-supabase.mjs"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "pg": "^8.16.3"
  }
}
