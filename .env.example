# Shared
NODE_ENV=development

# Web (Cloudflare Pages) — full URL (http/https); baked in at build time.
# Production: Railway origin (cross-origin), OR your Pages/site URL if GOLD_API_ORIGIN is set (proxy).
VITE_API_BASE_URL=http://localhost:8787
# Pages-only: Railway API origin for /v1/* edge proxy (see apps/web/functions/v1/). Omit locally if unused.
# GOLD_API_ORIGIN=https://your-service.up.railway.app

# API (Railway / Supabase Postgres)
PORT=8787
API_BASE_URL=http://localhost:8787
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
JWT_SECRET=CHANGE_ME_STRONG_SECRET
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Optional fallback for legacy HS256 projects. Prefer JWKS verification via SUPABASE_URL.
SUPABASE_JWT_SECRET=
# Public URL the API / job:spot can fetch (e.g. https://your-domain/spot-feed.json). Not localhost on a remote VPS.
SPOT_PRIMARY_FEED_URL=https://example.com/spot-feed.json
SPOT_FALLBACK_FEED_URL=https://data-asg.goldprice.org/dbXRates/USD
# Enables POST /v1/spot/push with Authorization: Bearer <same value>. VPS scraper uses the same secret in GOLD_API_BASE_URL + SPOT_PUSH_SECRET flow.
SPOT_PUSH_SECRET=
CORS_ORIGIN=http://localhost:5173

# VPS only (spot_scraper.py): push scraped prices into API (optional; same SPOT_PUSH_SECRET as Railway).
# GOLD_API_BASE_URL=https://your-railway-api.example.com
# SPOT_PUSH_SECRET=same-as-railway
